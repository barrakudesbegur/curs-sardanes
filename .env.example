# Public build-time env vars, exposed to the client via $env/static/public.
# Copy this file to `.env` for local dev/build/test. These are NOT secrets.

# TODO(owner): Kudi's WhatsApp number in international format (digits only, or with
# +/spaces — the wa.me helper strips everything but digits). Placeholder below.
PUBLIC_WA_NUMBER=34600000000

# Prefilled WhatsApp message. This exact text is the trigger the bot listens for,
# so keep it in sync with the whatsapp-bot flow trigger.
PUBLIC_WA_PREFILL=Explica'm això del curs de sardanes 💃
