# Public build-time env var, exposed to the client via $env/static/public.
# Copy this file to `.env` for local dev/build/test. This is NOT a secret.

# TODO(owner): Kudi's WhatsApp number in international format (digits only, or with
# +/spaces — the wa.me helper strips everything but digits). Placeholder below.
# For a free trial, use the Meta WhatsApp Cloud API *test number* (see docs/DEPLOY.md).
PUBLIC_WA_NUMBER=34600000000

# NOTE: the prefilled message is intentionally NOT an env var. It is hardcoded in
# src/lib/wa.ts (WA_PREFILL) because it must exactly match the bot's flow trigger.
